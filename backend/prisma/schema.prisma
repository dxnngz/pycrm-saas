generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id            Int           @id @default(autoincrement())
  name          String        @db.VarChar(100)
  domain        String?       @unique @db.VarChar(100)
  plan          String        @default("free") @db.VarChar(20)
  settings      Json?         @default("{}")
  created_at    DateTime?     @default(now()) @db.Timestamp(6)
  audit_logs    AuditLog[]
  clients       Client[]
  contacts      Contact[]
  documents     Document[]
  events        Event[]
  opportunities Opportunity[]
  products      Product[]
  tasks         Task[]
  users         User[]
  automations   Automation[]

  @@map("tenants")
}

model User {
  id              Int             @id @default(autoincrement())
  tenant_id       Int
  name            String          @db.VarChar(100)
  email           String          @unique @db.VarChar(100)
  password        String          @db.VarChar(255)
  role            String?         @default("empleado") @db.VarChar(20)
  created_at      DateTime?       @default(now()) @db.Timestamp(6)
  deleted_at      DateTime?       @db.Timestamp(6)
  audit_logs      AuditLog[]
  events          Event[]
  opportunities   Opportunity[]   @relation("UserOpportunities")
  password_resets PasswordReset[]
  refresh_tokens  RefreshToken[]
  mfa_enabled     Boolean         @default(false)
  mfa_secret      String?         @db.VarChar(255)
  mfa_recovery_codes String[]     @default([])
  tasks           Task[]
  tenant          Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, email], map: "unique_users_tenant_email")
  @@index([tenant_id, email], map: "idx_users_tenant_email")
  @@index([tenant_id, created_at], map: "idx_users_tenant_date")
  @@map("users")
}

model Client {
  id            Int           @id @default(autoincrement())
  tenant_id     Int
  name          String        @db.VarChar(100)
  company       String?       @db.VarChar(100)
  email         String?       @db.VarChar(100)
  phone         String?       @db.VarChar(20)
  status        String?       @default("activo") @db.VarChar(20)
  created_at    DateTime?     @default(now()) @db.Timestamp(6)
  deleted_at    DateTime?     @db.Timestamp(6)
  tenant        Tenant        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  contacts      Contact[]
  documents     Document[]
  events        Event[]
  opportunities Opportunity[]
  tasks         Task[]

  @@unique([id, tenant_id])
  @@index([tenant_id, created_at], map: "idx_clients_tenant_date")
  @@index([tenant_id, status], map: "idx_clients_tenant_status")
  @@index([tenant_id], map: "idx_clients_tenant")
  @@map("clients")
}

model Contact {
  id           Int       @id @default(autoincrement())
  tenant_id    Int
  client_id    Int?
  type         String    @db.VarChar(50)
  description  String?
  contact_date DateTime? @default(now()) @db.Timestamp(6)
  deleted_at   DateTime? @db.Timestamp(6)
  client       Client?   @relation(fields: [client_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tenant       Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, client_id], map: "idx_contacts_tenant_client")
  @@index([tenant_id, contact_date], map: "idx_contacts_tenant_date")
  @@map("contacts")
}

model Opportunity {
  id                   Int        @id @default(autoincrement())
  tenant_id            Int
  client_id            Int?
  assigned_to          Int?
  product              String     @db.VarChar(100)
  amount               Decimal    @db.Decimal(12, 2)
  status               String?    @default("pendiente") @db.VarChar(20)
  estimated_close_date DateTime?  @db.Date
  interactions         Int?       @default(0)
  created_at           DateTime?  @default(now()) @db.Timestamp(6)
  deleted_at           DateTime?  @db.Timestamp(6)
  version              Int        @default(1)
  documents            Document[]
  owner                User?      @relation("UserOpportunities", fields: [assigned_to], references: [id], onUpdate: NoAction)
  client               Client?    @relation(fields: [client_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tenant               Tenant     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([id, tenant_id])
  @@index([tenant_id, status], map: "idx_opps_tenant_status")
  @@index([tenant_id, created_at], map: "idx_opps_tenant_date")
  @@index([tenant_id, assigned_to], map: "idx_opps_tenant_assigned")
  @@index([tenant_id, client_id], map: "idx_opps_tenant_client")
  @@map("opportunities")
}

model Task {
  id         Int       @id @default(autoincrement())
  tenant_id  Int
  user_id    Int?
  client_id  Int?
  title      String    @db.VarChar(255)
  deadline   DateTime? @db.Timestamp(6)
  priority   String?   @default("Media") @db.VarChar(20)
  completed  Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  deleted_at DateTime? @db.Timestamp(6)
  version    Int       @default(1)
  client     Client?   @relation(fields: [client_id], references: [id], onUpdate: NoAction)
  tenant     Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user       User?     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([id, tenant_id])
  @@index([tenant_id, completed], map: "idx_tasks_tenant_completed")
  @@index([tenant_id, created_at], map: "idx_tasks_tenant_date")
  @@index([tenant_id, client_id], map: "idx_tasks_tenant_client")
  @@index([tenant_id, user_id], map: "idx_tasks_tenant_user")
  @@map("tasks")
}

model Event {
  id          Int       @id @default(autoincrement())
  tenant_id   Int
  user_id     Int?
  client_id   Int?
  title       String
  description String?
  start_date  DateTime  @db.Timestamp(6)
  end_date    DateTime  @db.Timestamp(6)
  color       String?   @default("#4f46e5")
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  deleted_at  DateTime? @db.Timestamp(6)
  version     Int       @default(1)
  client      Client?   @relation(fields: [client_id], references: [id], onUpdate: NoAction)
  tenant      Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([tenant_id, user_id], map: "idx_events_tenant_user")
  @@map("events")
}

model Product {
  id          Int       @id @default(autoincrement())
  tenant_id   Int
  name        String
  description String?
  price       Decimal   @db.Decimal(12, 2)
  category    String?
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  deleted_at  DateTime? @db.Timestamp(6)
  version     Int       @default(1)
  tenant      Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([id, tenant_id])
  @@index([tenant_id], map: "idx_products_tenant")
  @@index([tenant_id, created_at], map: "idx_products_tenant_date")
  @@map("products")
}

model Document {
  id             Int          @id @default(autoincrement())
  tenant_id      Int
  client_id      Int?
  opportunity_id Int?
  name           String
  type           String
  status         String?      @default("draft")
  amount         Decimal?     @db.Decimal(12, 2)
  created_at     DateTime?    @default(now()) @db.Timestamp(6)
  deleted_at     DateTime?    @db.Timestamp(6)
  version        Int          @default(1)
  client         Client?      @relation(fields: [client_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  opportunity    Opportunity? @relation(fields: [opportunity_id], references: [id], onUpdate: NoAction)
  tenant         Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, client_id], map: "idx_documents_tenant_client")
  @@index([tenant_id, opportunity_id], map: "idx_documents_tenant_opp")
  @@index([tenant_id, created_at], map: "idx_documents_tenant_date")
  @@map("documents")
}

model RefreshToken {
  id         Int       @id @default(autoincrement())
  user_id    Int?
  token      String    @unique
  expires_at DateTime  @db.Timestamp(6)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  user       User?     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_refresh_tokens_user_id")
  @@map("refresh_tokens")
}

model PasswordReset {
  id         Int       @id @default(autoincrement())
  user_id    Int?
  token      String    @unique
  expires_at DateTime  @db.Timestamp(6)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  user       User?     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_password_resets_user_id")
  @@map("password_resets")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  entity     String   @db.VarChar(50)
  entity_id  Int
  tenant_id  Int
  action     String   @db.VarChar(20)
  user_id    Int?
  request_id String?  @db.VarChar(100)
  changes    Json?
  created_at DateTime @default(now()) @db.Timestamp(6)
  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [user_id], references: [id])

  @@index([tenant_id, entity, entity_id], map: "idx_audit_tenant_entity")
  @@index([tenant_id, user_id], map: "idx_audit_tenant_user")
  @@index([tenant_id, created_at], map: "idx_audit_tenant_date")
  @@index([created_at], map: "idx_audit_global_date")
  @@map("audit_logs")
}

model Automation {
  id          Int         @id @default(autoincrement())
  tenant_id   Int
  name        String      @db.VarChar(255)
  description String?     @db.Text
  active      Boolean     @default(true)
  created_at  DateTime?   @default(now()) @db.Timestamp(6)
  updated_at  DateTime?   @default(now()) @updatedAt @db.Timestamp(6)
  deleted_at  DateTime?   @db.Timestamp(6)
  
  tenant      Tenant      @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  triggers    Trigger[]
  actions     Action[]

  @@index([tenant_id], map: "idx_automations_tenant")
  @@map("automations")
}

model Trigger {
  id             Int         @id @default(autoincrement())
  automation_id  Int
  event_name     String      @db.VarChar(100) // e.g. 'opportunity.created'
  
  automation     Automation  @relation(fields: [automation_id], references: [id], onDelete: Cascade)
  conditions     Condition[]

  @@index([automation_id], map: "idx_triggers_automation")
  @@map("triggers")
}

model Condition {
  id             Int         @id @default(autoincrement())
  trigger_id     Int
  field          String      @db.VarChar(100) // e.g. 'status'
  operator       String      @db.VarChar(20)  // e.g. 'equals', 'greater_than'
  value          String      @db.VarChar(255) // e.g. 'negociacion'
  
  trigger        Trigger     @relation(fields: [trigger_id], references: [id], onDelete: Cascade)

  @@index([trigger_id], map: "idx_conditions_trigger")
  @@map("conditions")
}

model Action {
  id             Int         @id @default(autoincrement())
  automation_id  Int
  type           String      @db.VarChar(100) // e.g. 'create_task', 'send_email'
  payload        Json        // Context variables or text template
  order          Int         @default(0)
  
  automation     Automation  @relation(fields: [automation_id], references: [id], onDelete: Cascade)

  @@index([automation_id], map: "idx_actions_automation")
  @@map("actions")
}
