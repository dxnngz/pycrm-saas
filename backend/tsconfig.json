{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ESNext",
    "outDir": "./dist",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": false,
    "verbatimModuleSyntax": false,
    "types": [
      "node"
    ]
  },
  "include": [
    "src",
    "prisma",
    "tests"
  ],
  "exclude": [
    "node_modules"
  ]
}